---
interface Props {
  dateDisplay: string;
}
const { dateDisplay } = Astro.props;
---
<header>
  <div class="logo">ORIGINE // CAISSE</div>
  <div class="header-right">
    <div class="period-tabs">
      <button class="period-tab active" data-period="today">Aujourd'hui</button>
      <button class="period-tab" data-period="week">7 jours</button>
      <button class="period-tab" data-period="month">30 jours</button>
    </div>
    <div class="date-display">{dateDisplay}</div>
  </div>
</header>

<style>
  header {
    padding: 18px 32px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 17px; color: var(--accent); }
  .header-right { display: flex; align-items: center; gap: 16px; }
  .date-display { font-size: 12px; color: var(--muted); }
  .period-tabs { display: flex; gap: 4px; }
  .period-tab {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 6px;
    padding: 5px 12px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    cursor: pointer;
    transition: all 0.12s;
  }
  .period-tab:hover { border-color: var(--accent); color: var(--text); }
  .period-tab.active { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
</style>
