---
import { db } from '../lib/turso';
import AppHeader from '../components/AppHeader.astro';
import EntryForm from '../components/EntryForm.astro';
import StatsPanel from '../components/StatsPanel.astro';

const result = await db.execute({
  sql: `SELECT * FROM entries WHERE site = ? AND date = date('now') ORDER BY created_at DESC`,
  args: ['VR Café']
});
const todayEntries = result.rows as any[];

const totalGroups = todayEntries.length;
const totalPeople = todayEntries.reduce((s, e) => s + (e.total || 0), 0);

const originCounts: Record<string, number> = {};
todayEntries.forEach(e => {
  const key = e.origin_label + (e.sub_origin ? ` — ${e.sub_origin}` : '');
  originCounts[key] = (originCounts[key] || 0) + e.total;
});
const originStats = Object.entries(originCounts).sort((a, b) => b[1] - a[1]);
const maxCount = originStats[0]?.[1] || 1;

const dateDisplay = new Date().toLocaleDateString('fr-FR', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Origine Clients — Caisse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0d0d0f;
      --surface: #16161a;
      --border: #2a2a30;
      --accent: #c8f135;
      --accent-dim: rgba(200,241,53,0.12);
      --text: #e8e8ec;
      --muted: #6b6b7a;
      --success: #00d68f;
      --danger: #ff4d6d;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    main {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 380px;
      overflow: hidden;
    }

    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--success);
      color: #0d0d0f;
      padding: 11px 22px;
      border-radius: 30px;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 13px;
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      z-index: 1000;
      pointer-events: none;
    }
    .toast.show { transform: translateX(-50%) translateY(0); }
    .toast.error { background: var(--danger); }
  </style>
</head>
<body>

<AppHeader dateDisplay={dateDisplay} />

<main>
  <EntryForm />
  <StatsPanel
    totalGroups={totalGroups}
    totalPeople={totalPeople}
    originStats={originStats}
    todayEntries={todayEntries}
    maxCount={maxCount}
  />
</main>

<div class="toast" id="toast">Entrée enregistrée ✓</div>

<script>
  interface State {
    adults: number;
    children: number;
    origin: string | null;
    originLabel: string | null;
    sub: string | null;
  }

  let state: State = { adults: 1, children: 0, origin: null, originLabel: null, sub: null };
  let currentPeriod = 'today';

  function adjust(field: 'adults' | 'children', delta: number) {
    state[field] = Math.max(field === 'adults' ? 1 : 0, state[field] + delta);
    const el = document.getElementById(field + '-val');
    if (el) el.textContent = String(state[field]);
  }

  function selectOrigin(btn: HTMLElement) {
    document.querySelectorAll('.origin-btn').forEach(b => b.classList.remove('selected'));
    document.querySelectorAll('.sub-options').forEach(s => s.classList.remove('visible'));
    document.querySelectorAll('.sub-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    state.origin = btn.dataset.origin ?? null;
    state.originLabel = btn.dataset.label ?? null;
    state.sub = null;
    const sub = document.getElementById('sub-' + state.origin);
    if (sub) sub.classList.add('visible');
  }

  function selectSub(btn: HTMLElement) {
    document.querySelectorAll('.sub-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    state.sub = btn.textContent?.trim() ?? null;
  }

  async function submitEntry() {
    if (!state.origin) { showToast('Sélectionne une source', true); return; }
    const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
    if (!btn) return;
    const noteField = document.getElementById('noteField') as HTMLInputElement | null;
    btn.disabled = true;
    btn.textContent = 'Envoi…';

    try {
      const res = await fetch('/api/entries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          origin: state.origin,
          origin_label: state.originLabel,
          sub_origin: state.sub,
          adults: state.adults,
          children: state.children,
          note: noteField?.value.trim() ?? '',
          site: 'VR Café'
        })
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error);

      state = { adults: 1, children: 0, origin: null, originLabel: null, sub: null };
      const adultsVal = document.getElementById('adults-val');
      const childrenVal = document.getElementById('children-val');
      if (adultsVal) adultsVal.textContent = '1';
      if (childrenVal) childrenVal.textContent = '0';
      if (noteField) noteField.value = '';
      document.querySelectorAll('.origin-btn').forEach(b => b.classList.remove('selected'));
      document.querySelectorAll('.sub-options').forEach(s => s.classList.remove('visible'));
      document.querySelectorAll('.sub-btn').forEach(b => b.classList.remove('selected'));

      showToast('Entrée enregistrée ✓');
      await refreshStats();
    } catch (err) {
      showToast('Erreur : ' + (err instanceof Error ? err.message : String(err)), true);
    } finally {
      btn.disabled = false;
      btn.textContent = "✓ Enregistrer l'entrée";
    }
  }

  async function refreshStats() {
    try {
      const res = await fetch(`/api/stats?period=${currentPeriod}&site=VR Café`);
      const data = await res.json();
      if (!res.ok) return;

      const statGroups = document.getElementById('stat-groups');
      const statPeople = document.getElementById('stat-people');
      if (statGroups) statGroups.textContent = data.stats.totalGroups;
      if (statPeople) statPeople.textContent = data.stats.totalPeople;

      const bars = document.getElementById('bars-container');
      const max = data.stats.originStats[0]?.count || 1;
      if (bars) {
        bars.innerHTML = data.stats.originStats.length === 0
          ? '<div class="empty">Aucune donnée</div>'
          : data.stats.originStats.map((s: { label: string; count: number }) => `
              <div class="bar-row">
                <div class="bar-label" title="${s.label}">${s.label}</div>
                <div class="bar-track"><div class="bar-fill" style="width:${Math.round(s.count/max*100)}%"></div></div>
                <div class="bar-val">${s.count}</div>
              </div>`).join('');
      }

      const recent = document.getElementById('recent-list');
      if (recent) {
        recent.innerHTML = (data.entries?.length || 0) === 0
          ? '<div class="empty">Aucune entrée</div>'
          : data.entries.slice(0, 6).map((e: { origin_label: string; sub_origin: string | null; total: number; heure: string }) => `
              <div class="entry-pill">
                <span class="entry-tag">${e.origin_label}${e.sub_origin ? ' · ' + e.sub_origin : ''}</span>
                <span class="entry-meta">${e.total} pers. · ${e.heure}</span>
              </div>`).join('');
      }
    } catch (err) {
      console.error('Stats refresh error:', err);
    }
  }

  function setPeriod(btn: HTMLElement) {
    document.querySelectorAll('.period-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    currentPeriod = btn.dataset.period ?? 'today';
    const labels: Record<string, string> = { today: "Aujourd'hui", week: '7 derniers jours', month: '30 derniers jours' };
    const periodLabel = document.getElementById('period-label');
    if (periodLabel) periodLabel.textContent = labels[currentPeriod];
    refreshStats();
  }

  function exportCSV() {
    window.location.href = `/api/export?period=${currentPeriod}&site=VR Café`;
  }

  function showToast(msg = 'Entrée enregistrée ✓', isError = false) {
    const t = document.getElementById('toast');
    if (!t) return;
    t.textContent = msg;
    t.classList.toggle('error', isError);
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  // Event listeners
  document.querySelectorAll<HTMLButtonElement>('[data-field][data-delta]').forEach(btn => {
    btn.addEventListener('click', () => {
      const field = btn.dataset.field as 'adults' | 'children';
      const delta = Number(btn.dataset.delta);
      adjust(field, delta);
    });
  });

  document.querySelectorAll<HTMLElement>('.origin-btn').forEach(btn => {
    btn.addEventListener('click', () => selectOrigin(btn));
  });

  document.querySelectorAll<HTMLElement>('.sub-btn').forEach(btn => {
    btn.addEventListener('click', () => selectSub(btn));
  });

  document.getElementById('submitBtn')?.addEventListener('click', () => submitEntry());

  document.querySelectorAll<HTMLElement>('.period-tab').forEach(btn => {
    btn.addEventListener('click', () => setPeriod(btn));
  });

  document.getElementById('exportBtn')?.addEventListener('click', () => exportCSV());

  refreshStats();
</script>

</body>
</html>
